# Normalize line endings
* text=auto eol=lf

# Force LF for source code
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff2 binary
